{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/before-git-push.sh",
        "matcher": "git push",
        "failClosed": false
      },
      {
        "command": ".cursor/hooks/before-git-commit.sh",
        "matcher": "git commit",
        "failClosed": false
      }
    ]
  }
}
