# Copy to .env and fill in values. Never commit .env.

# Postgres connection string (local Docker, Render internal URL, etc.)
DATABASE_URL=postgresql://signalbrief:signalbrief@localhost:5432/signalbrief

# Briefing provider: rules-fallback (production) or ollama (local only)
BRIEFING_PROVIDER=rules-fallback

# Ollama — local development only; keep disabled in production
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
# qwen3:14b — project default; lighter alternatives in docs/QUICKSTART.md
OLLAMA_MODEL=qwen3:14b

# Node environment
NODE_ENV=development
