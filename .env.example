# Copy to .env and fill in values. Never commit .env.

# Postgres connection string (local Docker, Render internal URL, etc.)
DATABASE_URL=postgresql://signalbrief:signalbrief@localhost:5432/signalbrief

# --- Local AI (Ollama) — default for development ---
BRIEFING_PROVIDER=ollama
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
# qwen3:14b — project default; lighter alternatives in docs/QUICKSTART.md
OLLAMA_MODEL=qwen3:14b

# --- Production / Render (no API cost) — use rules-fallback instead:
# BRIEFING_PROVIDER=rules-fallback
# OLLAMA_ENABLED=false

# Node environment
NODE_ENV=development
